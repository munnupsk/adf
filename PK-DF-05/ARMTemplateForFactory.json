						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "AzureSqlEmpDeptTable",
								"type": "DatasetReference"
							},
							"name": "sink1"
						}
					],
					"transformations": [
						{
							"name": "join1"
